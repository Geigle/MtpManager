{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MtpManager",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/mm.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "justMyCode": true
        },
        {
            "name": "MtpManager (DEBUG)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/mm.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "justMyCode": true,
            "env": {
                "MTP_MANAGER_DEBUG": "1"
            },
            "args": ["--verbose"]
        }
    ]
}
